{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "vant-flow": [
                "../../dist/vant-flow",
                "../../dist/vant-flow/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}
