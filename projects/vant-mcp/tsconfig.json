{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@vant-flow/models": [
                "../vant-flow/src/lib/models/document.model.ts"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}