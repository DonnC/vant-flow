{
    "name": "Quality Inspection Report",
    "module": "Quality Management",
    "version": "1.2.0",
    "description": "Comprehensive quality control report for manufacturing batches. Tracks inspections, defect logs, and clearance status.",
    "intro_text": "<b>Quality Assurance Protocol:</b> Ensure all batches are inspected against the <i>ISO-9001</i> standard. Document any deviations in the Defect Log section.",
    "intro_color": "blue",
    "sections": [
        {
            "id": "sec_gen",
            "label": "General Information",
            "columns_count": 2,
            "columns": [
                {
                    "id": "c1",
                    "fields": [
                        {
                            "id": "f_inspector",
                            "fieldname": "inspector_name",
                            "fieldtype": "Data",
                            "label": "Lead Inspector",
                            "mandatory": true,
                            "placeholder": "Enter full name"
                        },
                        {
                            "id": "f_batch",
                            "fieldname": "batch_id",
                            "fieldtype": "Data",
                            "label": "Batch ID",
                            "mandatory": true,
                            "regex": "^QC-[A-Z]{2}-[0-9]{4}$",
                            "description": "Format: QC-XX-0000"
                        }
                    ]
                },
                {
                    "id": "c2",
                    "fields": [
                        {
                            "id": "f_date",
                            "fieldname": "inspection_date",
                            "fieldtype": "Date",
                            "label": "Inspection Date"
                        },
                        {
                            "id": "f_shift",
                            "fieldname": "shift",
                            "fieldtype": "Select",
                            "label": "Work Shift",
                            "options": "Morning\nAfternoon\nNight",
                            "default": "Morning"
                        }
                    ]
                }
            ]
        },
        {
            "id": "sec_params",
            "label": "Inspection Parameters",
            "columns_count": 2,
            "columns": [
                {
                    "id": "c31",
                    "fields": [
                        {
                            "id": "f_visual",
                            "fieldname": "visual_check",
                            "fieldtype": "Check",
                            "label": "Visual Inspection Passed",
                            "default": 1
                        },
                        {
                            "id": "f_dimen",
                            "fieldname": "dimensions_check",
                            "fieldtype": "Check",
                            "label": "Dimensional Accuracy Verified",
                            "default": 1
                        }
                    ]
                },
                {
                    "id": "c32",
                    "fields": [
                        {
                            "id": "f_score",
                            "fieldname": "quality_score",
                            "fieldtype": "Int",
                            "label": "Overall Quality Score (0-100)",
                            "default": 100,
                            "description": "Calculated based on detected issues."
                        }
                    ]
                }
            ]
        },
        {
            "id": "sec_defects",
            "label": "Defect Log",
            "columns_count": 1,
            "columns": [
                {
                    "id": "c41",
                    "fields": [
                        {
                            "id": "f_defect_table",
                            "fieldname": "defect_log",
                            "fieldtype": "Table",
                            "label": "Detected Defects",
                            "table_fields": [
                                {
                                    "id": "tc1",
                                    "fieldname": "defect_type",
                                    "label": "Type",
                                    "fieldtype": "Select",
                                    "options": "Surface Scratch\nColor Mismatch\nStructural Crack\nFunctional Failure",
                                    "mandatory": true
                                },
                                {
                                    "id": "tc2",
                                    "fieldname": "severity",
                                    "label": "Severity",
                                    "fieldtype": "Select",
                                    "options": "Low\nMedium\nHigh\nCritical",
                                    "default": "Low"
                                },
                                {
                                    "id": "tc3",
                                    "fieldname": "resolved",
                                    "label": "Auto-Fix Attempted",
                                    "fieldtype": "Check"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "id": "sec_clearance",
            "label": "Security Clearance",
            "depends_on": "doc.quality_score < 80",
            "columns_count": 1,
            "columns": [
                {
                    "id": "c51",
                    "fields": [
                        {
                            "id": "f_clearance",
                            "fieldname": "btn_request_clearance",
                            "fieldtype": "Button",
                            "label": "Request Override Clearance",
                            "options": "danger"
                        }
                    ]
                }
            ]
        },
        {
            "id": "sec_util",
            "label": "Form Utilities",
            "columns_count": 2,
            "columns": [
                {
                    "id": "c61",
                    "fields": [
                        {
                            "id": "f_reset",
                            "fieldname": "btn_reset_all",
                            "fieldtype": "Button",
                            "label": "Reset Report",
                            "options": "ghost"
                        }
                    ]
                }
            ]
        }
    ],
    "actions": {
        "save": {
            "label": "Save Progress",
            "visible": true,
            "type": "secondary"
        },
        "submit": {
            "label": "Approve Batch",
            "visible": true,
            "type": "primary"
        }
    },
    "client_script": "frm.on('refresh', (val, frm) => {\n    frm.msgprint('Quality Inspection System initialized.', 'info');\n});\n\nfrm.on('quality_score', (val, frm) => {\n    if (val < 50) {\n        frm.set_intro('CRITICAL QUALITY LEVEL: Batch rejection recommended.', 'red');\n    } else if (val < 80) {\n        frm.set_intro('CAUTION: Manual clearance required for score < 80.', 'orange');\n    } else {\n        frm.set_intro(null);\n    }\n});\n\nfrm.on('defect_log_add', (data, frm) => {\n    frm.msgprint('New defect entry added at row ' + (data.index + 1) + '. Please specify type.', 'warning');\n    const currentScore = frm.get_value('quality_score');\n    frm.set_value('quality_score', Math.max(0, currentScore - 10));\n});\n\nfrm.on('defect_log_remove', (data, frm) => {\n    frm.msgprint('Defect entry removed. Recalculating score...', 'info');\n    const currentScore = frm.get_value('quality_score');\n    frm.set_value('quality_score', Math.min(100, currentScore + 10));\n});\n\nfrm.on('btn_request_clearance', (val, frm) => {\n    frm.prompt([\n        { label: 'Supervisor Name', fieldname: 'supervisor', fieldtype: 'Data', mandatory: true },\n        { label: 'Clearance Code', fieldname: 'code', fieldtype: 'Password', mandatory: true },\n        { label: 'Approval Reason', fieldname: 'reason', fieldtype: 'Select', options: 'Testing Purposes\\nUrgent Delivery\\nKnown Component Issue' }\n    ], (res) => {\n        frm.msgprint('Clearance requested by ' + res.supervisor + ' for reason: ' + res.reason);\n        frm.call({\n            method: 'validate_clearance_code',\n            args: { code: res.code },\n            freeze: true,\n            callback: (r) => {\n                frm.msgprint('Remote Authorization: ' + r.message, 'success');\n                frm.set_intro('OVERRIDE APPROVED: Batch marked for conditional release.', 'green');\n            }\n        });\n    }, 'Manager Clearance');\n});\n\nfrm.on('btn_reset_all', (val, frm) => {\n    frm.confirm('Reset this report? All unsaved data and custom banners will be cleared.', () => {\n        frm.reset();\n    });\n});"
}